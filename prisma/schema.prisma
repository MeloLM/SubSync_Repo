// Schema del database SubSync.
// Regola 1 (ARCHITECTURE.md): gli importi monetari sono Decimal, mai Float.

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // runtime: transaction pooler (pgbouncer)
  directUrl = env("DIRECT_URL")   // migrazioni: session pooler (direct)
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// Stato di un invito alla condivisione di un abbonamento (Split-Billing, Sprint 5).
enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  createdAt     DateTime             @default(now())
  subscriptions Subscription[]
  memberships   SubscriptionMember[] // Abbonamenti condivisi con questo utente
}

model Subscription {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  amount          Decimal      @db.Decimal(12, 2) // Regola 1: Decimal, mai Float
  currency        String       @default("EUR")
  billingCycle    BillingCycle
  nextRenewalDate DateTime // Regola 2: forzata a 00:00:00 UTC pre-salvataggio
  createdAt       DateTime     @default(now())
  payments        PaymentLog[]
  members         SubscriptionMember[] // Split-Billing: partecipanti invitati

  @@index([userId])
}

// Split-Billing (Sprint 5): un partecipante invitato a dividere il costo di un
// abbonamento. Il proprietario (Subscription.user) partecipa implicitamente con
// peso 1; i membri qui elencati ricevono un invito e, una volta accettato, sono
// legati al loro account (`userId`) e vedono l'abbonamento condiviso.
model SubscriptionMember {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  // Account dell'invitato: null finché l'invito non viene accettato.
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Email dell'invito: usata per il matching invito → account al login.
  email          String
  status         InviteStatus @default(PENDING)
  // Peso della quota (Regola 1: Decimal). Default 1 = parti uguali col proprietario.
  shareWeight    Decimal      @default(1) @db.Decimal(12, 4)
  // Settlement: la quota dovuta è stata saldata al proprietario?
  settled        Boolean      @default(false)
  settledAt      DateTime?
  createdAt      DateTime     @default(now())

  @@unique([subscriptionId, email])
  @@index([subscriptionId])
  @@index([userId])
  @@index([email])
}

model PaymentLog {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Decimal      @db.Decimal(12, 2) // Regola 1
  paidAt         DateTime     @default(now())

  @@index([subscriptionId])
}
