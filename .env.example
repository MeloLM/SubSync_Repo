# Template variabili d'ambiente. Copia i valori REALI in:
#   .env        → DATABASE_URL / DIRECT_URL (lette da Prisma)
#   .env.local  → NEXT_PUBLIC_SUPABASE_* / CRON_SECRET (lette da Next)
# Entrambi sono gitignorati. NON mettere valori reali in questo file.

# --- Database ---
# Locale (Docker): combacia con docker-compose.yml.
# Supabase: usa la connection string del pooler (dashboard → Connect → Prisma).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Supabase Auth (@supabase/ssr) — dal dashboard del progetto ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-SUPABASE-ANON-OR-PUBLISHABLE-KEY"

# --- Cron ---
# Autorizza /api/cron/renewals (Vercel invia "Authorization: Bearer <CRON_SECRET>").
CRON_SECRET="change-me"
